{
  "name": "@builderhub/mcp-youtube",
  "version": "1.0.0",
  "description": "MCP server for YouTube — upload videos, manage playlists, moderate comments via Claude Code/Desktop",
  "type": "module",
  "bin": { "mcp-youtube": "./dist/index.js" },
  "main": "./dist/index.js",
  "files": ["dist", "scripts"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "get-token": "npx tsx scripts/get-youtube-token.ts"
  },
  "publishConfig": { "access": "public" },
  "keywords": ["mcp", "youtube", "google", "claude", "ai", "model-context-protocol"],
  "author": "BuilderHub",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "googleapis": "^144.0.0",
    "google-auth-library": "^9.0.0",
    "zod": "^3.23.0",
    "dotenv": "^16.0.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0"
  },
  "engines": { "node": ">=18.0.0" }
}
